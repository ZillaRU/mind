{
  "name": "mind-slow",
  "displayName": "慢 mind",
  "description": "在工位上，给自己一段慢时光。专为程序员和白领设计的微休息活动。",
  "version": "0.1.0",
  "publisher": "zilla",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mind-slow.open",
        "title": "慢 mind: 开始一段慢时光",
        "category": "慢 mind"
      }
    ],
    "keybindings": [
      {
        "command": "mind-slow.open",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.2.0"
  }
}
